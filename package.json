{
    "name": "fmirror",
    "version": "1.0.0",
    "private": true,
    "description": "Watch source folders and sync them to one or more destinations respecting .fmirror-ignore files.",
    "main": "dist/fmirror.js",
    "type": "commonjs",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true });\"",
        "analyze": "node --import tsx src/index.ts analyze ./fmirror.config.json",
        "reconcile": "node --import tsx src/index.ts reconcile ./fmirror.config.json",
        "test": "node --import tsx --test src/**/*.test.ts",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "build": "npm run clean && npm run typecheck && npm run test && node --import tsx src/build.ts",
        "start": "node dist/fmirror.js ./fmirror.config.json",
        "dev": "node --import tsx src/index.ts ./fmirror.config.json",
        "install:local": "npm run build && node dist/fmirror.js install"
    },
    "dependencies": {
        "fs-extra": "^11.3.0",
        "ignore": "^7.0.5"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^24.0.0",
        "esbuild": "^0.27.4",
        "tsx": "^4.20.6",
        "typescript": "^5.9.2"
    }
}
